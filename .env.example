# =============================================================================
# 字幕烧录工具 · 环境变量模板
# Subtitle Burner · Environment variables template
# 使用方法 / Usage:
#   cp .env.example .env
#   # 然后修改 SECRET_KEY / AUTH_PASS 等敏感字段
# =============================================================================

# -----------------------------------------------------------------------------
# 端口绑定 / Port binding
# -----------------------------------------------------------------------------
# BIND_HOST: 留空或 0.0.0.0 表示监听全部网卡；如只允许局域网，设为 192.168.x.x
# BIND_PORT: 主机侧端口。TrueNAS 上若 8000 被占，改为 18000 等
BIND_HOST=0.0.0.0
BIND_PORT=8000

# -----------------------------------------------------------------------------
# 鉴权 / Authentication（⚠️ 首次启动后必须修改）
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# SESSION_SECRET 用于签名 Cookie / CSRF / 会话。
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=please-change-me-in-production-32bytes-min

# -----------------------------------------------------------------------------
# 日志 / Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# ffmpeg 参数 / ffmpeg options
# -----------------------------------------------------------------------------
# ---- 队列 / Queue ----
MAX_CONCURRENT_TASKS=2
# 单文件上传上限 MB
MAX_FILE_SIZE_MB=2048

# ---- 编码参数 / ffmpeg encoder (请编辑 main.py 改为硬编码) ----
# FFMPEG_PRESET (unused in main.py) / 体积折中（18 接近无损，28 体积更小；推荐 22-26）
# FFMPEG_CRF (unused in main.py)

# GPU profile 时生效。默认 h264_nvenc；如要 H.265 改为 hevc_nvenc
# FFMPEG_VCODEC (unused in main.py)

# -----------------------------------------------------------------------------
# GPU（仅 --profile gpu 时生效） / GPU (GPU profile only)
# -----------------------------------------------------------------------------
"all" 表示暴露所有 GPU；写 "0,1" 表示第 1、2 张；写 "1" 表示仅第 2 张
NVIDIA_VISIBLE_DEVICES=all